{
  "name": "urthmapper",
  "version": "1.1.0",
  "description": "Vacant land lead pipeline for Clearwater FL and surrounding counties",
  "type": "commonjs",
  "scripts": {
    "scrape": "node scrape-leads.js",
    "scrape:export": "node scrape-leads.js --export-app",
    "scrape:32137": "node scrape-leads.js --profile scraper/profiles/32137.json --export-app --skiptrace",
    "enrich:water": "node enrich-water.js --export-app",
    "enrich:investor": "node enrich-investor.js --export-app",
    "skiptrace": "node skiptrace-leads.js --export-app",
    "skiptrace:all": "node skiptrace-leads.js --export-app",
    "skiptrace:force": "node skiptrace-leads.js --export-app --force",
    "export:csv": "node export-leads-csv.js",
    "serve": "npx serve -l 8888 ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "undici": "^8.5.0"
  }
}
